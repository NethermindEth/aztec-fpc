# Aztec FPC — Testnet defaults
# Usage: docker compose -f docker-compose.public.yaml --env-file .env.testnet up

DEPLOYMENT=testnet
AZTEC_NODE_URL=https://rpc.testnet.aztec-labs.com
L1_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# --- Required (uncomment and set) ---
# FPC_DEPLOYER_SECRET_KEY=
# FPC_OPERATOR_SECRET_KEY=
# FPC_L1_DEPLOYER_KEY=
