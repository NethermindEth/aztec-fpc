{
  "name": "@aztec-fpc/contract-deployment",
  "version": "0.1.0",
  "description": "Bundleable FPC contract deployment CLI for devnet",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=bun --external @aztec/bb.js --external @aztec/noir-noirc_abi --external @aztec/noir-acvm_js --external pino",
    "typecheck": "tsc --noEmit",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@aztec/accounts": "4.0.0-devnet.2-patch.3",
    "@aztec/aztec.js": "4.0.0-devnet.2-patch.3",
    "@aztec/bb.js": "4.0.0-devnet.2-patch.3",
    "@aztec/foundation": "4.0.0-devnet.2-patch.3",
    "@aztec/noir-noirc_abi": "4.0.0-devnet.2-patch.3",
    "@aztec/noir-acvm_js": "4.0.0-devnet.2-patch.3",
    "@aztec/stdlib": "4.0.0-devnet.2-patch.3",
    "@aztec/wallets": "4.0.0-devnet.2-patch.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "engines": {
    "bun": "1.3.9"
  }
}
