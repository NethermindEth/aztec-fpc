{
  "name": "@nethermindeth/aztec-fpc-contract-deployment",
  "version": "0.1.0",
  "description": "Bundleable FPC contract deployment CLI for devnet",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=bun --external @aztec/bb.js --external @aztec/noir-noirc_abi --external @aztec/noir-acvm_js --external pino",
    "typecheck": "tsc --noEmit",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@aztec/accounts": "4.1.0-nightly.20260312.2",
    "@aztec/aztec.js": "4.1.0-nightly.20260312.2",
    "@aztec/bb.js": "4.1.0-nightly.20260312.2",
    "@aztec/ethereum": "4.1.0-nightly.20260312.2",
    "@aztec/foundation": "4.1.0-nightly.20260312.2",
    "@aztec/l1-artifacts": "4.1.0-nightly.20260312.2",
    "@aztec/noir-noirc_abi": "4.1.0-nightly.20260312.2",
    "@aztec/noir-acvm_js": "4.1.0-nightly.20260312.2",
    "@aztec/stdlib": "4.1.0-nightly.20260312.2",
    "@aztec/wallets": "4.1.0-nightly.20260312.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "viem": "npm:@aztec/viem@2.38.2"
  },
  "engines": {
    "bun": "1.3.9"
  }
}
