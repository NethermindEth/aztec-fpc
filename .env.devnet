# Aztec FPC — Devnet defaults
# Usage: docker compose -f docker-compose.public.yaml --env-file .env.devnet up

DEPLOYMENT=devnet
AZTEC_NODE_URL=https://v4-devnet-2.aztec-labs.com/
L1_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# --- Required (uncomment and set) ---
# FPC_DEPLOYER_SECRET_KEY=
# FPC_OPERATOR_SECRET_KEY=
# FPC_L1_DEPLOYER_KEY=
