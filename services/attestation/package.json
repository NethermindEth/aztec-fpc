{
  "name": "@nethermindeth/aztec-fpc-attestation",
  "version": "0.1.0",
  "type": "module",
  "description": "Quote-signing attestation service for the MultiAssetFPC",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=${BUILD_TARGET:-bun} --external @aztec/bb.js --external @aztec/noir-noirc_abi --external @aztec/noir-acvm_js --external pino --external lmdb --external ordered-binary",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "bun run dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@nethermindeth/aztec-fpc-contract-deployment": "workspace:*",
    "@aztec/accounts": "4.1.0-rc.4",
    "@aztec/aztec.js": "4.1.0-rc.4",
    "@aztec/bb.js": "4.1.0-rc.4",
    "@aztec/foundation": "4.1.0-rc.4",
    "@aztec/noir-acvm_js": "4.1.0-rc.4",
    "@aztec/noir-noirc_abi": "4.1.0-rc.4",
    "@aztec/pxe": "4.1.0-rc.4",
    "@aztec/stdlib": "4.1.0-rc.4",
    "@aztec/ethereum": "4.1.0-rc.4",
    "@aztec/wallets": "4.1.0-rc.4",
    "fastify-rate-limit": "npm:@fastify/rate-limit@9",
    "fastify": "^4.28.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "viem": "npm:@aztec/viem@2.38.2",
    "lmdb": "^3.2.0",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "imports": {
    "#test": {
      "bun": "bun:test",
      "default": "vitest"
    }
  },
  "engines": {
    "bun": "1.3.11"
  }
}
