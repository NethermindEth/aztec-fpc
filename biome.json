{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "package.json",
      "tsconfig.base.json",
      "services/*/src/**/*.ts",
      "services/*/test/**/*.ts",
      "services/*/package.json",
      "scripts/**/*.ts",
      "scripts/*/package.json",
      "fpc-sdk/src/**/*.ts",
      "fpc-sdk/test/**/*.ts",
      "fpc-sdk/package.json",
      "fpc-sdk/tsconfig.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true
  }
}
