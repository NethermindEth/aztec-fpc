{
  "name": "aztec-fpc",
  "version": "1.0.0",
  "author": "",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "description": "",
  "keywords": [],
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "ci": "bun run format && bun run biome:ci && bun run lint && bun run typecheck && bun run test:ts && bun run test:contracts",
    "biome:check": "biome check --write",
    "biome:ci": "biome ci",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check:docs:quote-schema": "bash scripts/check-docs-quote-schema.sh",
    "build": "bun run --workspaces --if-present build",
    "typecheck": "bun run --workspaces --if-present typecheck",

    "test": "bun run test:contracts && bun run test:ts",
    "test:ts": "bun run --filter @aztec-fpc/attestation --if-present test && bun run --filter @aztec-fpc/topup --if-present test",
    "test:services": "bun run test:ts",
    "test:contracts": "aztec compile --workspace --force && aztec test --package fpc && aztec test --package credit_fpc",

    "attestation:build": "bun run --filter @aztec-fpc/attestation build",
    "attestation:dev": "bun run --filter @aztec-fpc/attestation dev",
    "attestation:start": "bun run --filter @aztec-fpc/attestation start",
    "topup:build": "bun run --filter @aztec-fpc/topup build",
    "topup:dev": "bun run --filter @aztec-fpc/topup dev",
    "topup:start": "bun run --filter @aztec-fpc/topup start",

    "docker:build": "docker buildx bake",
    "docker:build:attestation": "docker buildx bake attestation",
    "docker:build:deploy": "docker buildx bake deploy",
    "docker:build:services": "docker buildx bake services",
    "docker:build:smoke": "docker buildx bake smoke",
    "docker:build:topup": "docker buildx bake topup",

    "generate:configs": "bash scripts/config/generate-service-configs.sh",
    "render:config:devnet": "bunx tsx scripts/services/render-config-from-manifest.ts --manifest ./deployments/devnet-manifest-v2.json",
    "deploy:fpc:local": "FPC_DEPLOY_ENV=local bash scripts/contract/deploy-fpc-devnet.sh",
    "deploy:fpc:devnet": "FPC_DEPLOY_ENV=devnet bash scripts/contract/deploy-fpc-devnet.sh",
    "verify:deploy:fpc:devnet": "bunx tsx scripts/contract/verify-fpc-devnet-deployment.ts --manifest ./deployments/devnet-manifest-v2.json",
    "smoke:deploy:fpc:devnet": "FPC_DEPLOY_ENV=devnet bash scripts/contract/devnet-postdeploy-smoke.sh --manifest ./deployments/devnet-manifest-v2.json",

    "smoke:deploy:fpc:local": "bash scripts/contract/deploy-smoke-local.sh",
    "smoke:fee-entrypoint:local": "bash scripts/contract/fee-entrypoint-local-smoke.sh",
    "smoke:credit-fpc:local": "bash scripts/contract/credit-fpc-local-smoke.sh",
    "smoke:services:local": "bash scripts/services/fpc-services-smoke.sh",
    "e2e:full-lifecycle:fpc:local": "bash scripts/services/fpc-full-lifecycle-e2e.sh",
    "e2e:full-lifecycle:credit:local": "bash scripts/services/credit-fpc-full-lifecycle-e2e.sh",
    "e2e:full-lifecycle:fpc:compose": "bash scripts/services/full-lifecycle-compose.sh fpc",
    "e2e:full-lifecycle:credit:compose": "bash scripts/services/full-lifecycle-compose.sh credit",
    "e2e:full-lifecycle:compose": "bash scripts/services/full-lifecycle-compose.sh both",

    "teardown": "pkill -f '[a]ztec' || true",

    "chaos:api": "FPC_CHAOS_MODE=api bun scripts/chaos/fpc-chaos-test.ts",
    "chaos:onchain": "FPC_CHAOS_MODE=onchain bun scripts/chaos/fpc-chaos-test.ts",
    "chaos:full": "FPC_CHAOS_MODE=full bun scripts/chaos/fpc-chaos-test.ts",
    "chaos:local": "bash scripts/chaos/fpc-chaos-local.sh"
  },
  "workspaces": [
    "scripts",
    "services/*"
  ]
}
